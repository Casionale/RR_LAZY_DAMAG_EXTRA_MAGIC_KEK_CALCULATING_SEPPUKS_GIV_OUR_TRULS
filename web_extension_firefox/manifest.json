{
  "manifest_version": 2,
  "name": "NS Cookie Bridge",
  "version": "0.1.0",
  "description": "Отправляет cookies Rival Regions в локальный web backend",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "http://localhost:5000/*",
    "https://rivalregions.com/*",
    "https://*.rivalregions.com/*",
    "https://rivalka.ru/*",
    "https://*.rivalka.ru/*",
    "https://*.ngrok-free.dev/*",
    "https://*.ngrok-free.app/*"
  ],
  "browser_action": {
    "default_title": "NS Cookie Bridge",
    "default_popup": "popup.html"
  },
  "applications": {
    "gecko": {
      "id": "ns-cookie-bridge@local"
    }
  }
}
